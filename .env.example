# Claw 外贸网站环境变量模板
# 复制此文件为 .env 并填写真实值

# ========== 必需变量 ==========

# 数据库（Render PostgreSQL）
DATABASE_URL=postgresql://user:password@host.render.com:5432/dbname

# JWT 认证
JWT_SECRET=your-random-secret-key-here

# ========== AI API Keys ==========

# 阿里云百炼（文生文/Embedding）
BAILIAN_API_KEY=sk-xxxxxxxxxxxx

# 腾讯混元（备用）
HUNYUAN_API_KEY=xxxxxxxxxxxx

# ========== CORS 配置 ==========

# 允许的前端域名（逗号分隔）
ALLOWED_ORIGINS=https://your-frontend.onrender.com,http://localhost:5173

# ========== 浏览器自动化（Playwright）==========

# 代理配置（国内访问 TikTok/YouTube 需要）
# 格式：http://ip:port
# 示例：PLAYWRIGHT_PROXY_URL=http://127.0.0.1:7890
# 留空则直连
PLAYWRIGHT_PROXY_URL=

# Session 保存目录（默认 ./browser-states）
BROWSER_STATE_DIR=./browser-states

# ========== 节点环境 ==========
NODE_ENV=production
PORT=10000

# ========== Dify 工作流集成 ==========
# Dify API 地址（末尾不要加斜杠）
DIFY_APP_URL=https://api.dify.ai/v1

# Dify API Key（在 Dify 后台 → 设置 → API Key）
DIFY_API_KEY=app-xxxxxxxxxxxxxxxxxxxx

# 自动发布阈值：选品评分 >= 此值时自动触发 OpenClaw 发布（默认 80）
DIFY_AUTO_PUBLISH_THRESHOLD=80

# OpenClaw Webhook 地址（Dify 评分达标后通知 OpenClaw 执行浏览器自动化）
# 本地开发： http://localhost:18789
# 生产环境： 填你的 OpenClaw 公网地址
OPENCLAW_WEBHOOK_URL=http://localhost:18789
